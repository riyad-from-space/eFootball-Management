# ─── eFootball Appifylab — environment variables ───────────────────────────
# Copy this file to .env.local for local dev, and set the same variables in
# your Vercel project settings for production. NEVER commit real keys.

# Supabase → Project Settings → Data API (or API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Supabase → Project Settings → API → service_role secret.
# SERVER-ONLY. Used by admin server actions to write data. Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET

# The single admin password (required to log in at /admin). Choose a strong value.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: secret used to sign the admin session cookie. If unset, the admin
# password is used as the signing key. Set this so sessions survive a password change.
SESSION_SECRET=any-long-random-string
